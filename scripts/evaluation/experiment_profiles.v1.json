{
  "id": "optlab-experiment-profiles-v1",
  "default": {
    "name": "通用实验配置",
    "must_include_sections": ["数学原理", "实验数据", "实验总结"],
    "required_fact_paths": [
      "payload.algorithm_name",
      "payload.algorithm",
      "payload.test_function",
      "payload.function"
    ],
    "numeric_patterns": [
      "x_star",
      "objective_value",
      "accuracy",
      "result",
      "final",
      "iteration",
      "sample_count",
      "length",
      "epsilon",
      "alpha",
      "beta",
      "c"
    ],
    "max_numeric_expectations": 12,
    "require_data_table": true,
    "min_table_rows": 1,
    "constraints": {
      "math_principle_disallow_terms": ["待补充"],
      "expected_summary_placeholder": "（由用户填写）"
    }
  },
  "profiles": [
    {
