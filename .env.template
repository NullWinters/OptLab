# 支持Sqlite和PostgreSQL，默认使用SQLite以方便本地开发。部署时请替换为PostgreSQL URI，并确保数据库已创建。
# 示例PostgreSQL URI格式：postgresql+asyncpg://username:password@address/database
# 示例SQLite URI格式：sqlite+aiosqlite:///./optlab.db
OPTLAB_DB_URI="sqlite+aiosqlite:///./optlab.db"

# auth / jwt
OPTLAB_SECRET_KEY="CHANGE_ME_TO_A_SECURE_RANDOM_KEY"
OPTLAB_ACCESS_TOKEN_MINUTES=30

# LLM (OpenAI-compatible)
# 支持任意 OpenAI-compatible 服务（DeepSeek / OpenAI / 本地模型等）
# LLM_BASE_URL 不设置则使用默认端点；LLM_MODEL_ID 按服务商文档填写
LLM_BASE_URL="https://api.deepseek.com/v1"
LLM_MODEL_ID="deepseek-chat"
LLM_API_KEY="CHANGE_ME_DEEPSEEK_KEY"
LLM_TEMPERATURE=0.25

# 聊天历史配置
CHAT_HISTORY_WINDOW_ROUNDS=10
CHAT_MESSAGE_RETENTION_DAYS=30

# 管理员凭据（通过 /admin/env 页面注册时自动写入）
# OPTLAB_ADMIN_USERNAME="admin"
# OPTLAB_ADMIN_PASSWORD_HASH="<argon2-hash>"
# OPTLAB_ADMIN_JWT_SECRET="<random-secret>"
