# OptLab 环境配置模板
# 复制此文件为 .env 并按需修改

# ── 数据库 ────────────────────────────────────────────
# 支持 SQLite 和 PostgreSQL，默认使用 SQLite 以便本地开发
# PostgreSQL 示例: postgresql+asyncpg://user:password@host/dbname
OPTLAB_DB_URI="sqlite+aiosqlite:///./optlab.db"

# ── 用户认证 JWT ──────────────────────────────────────
OPTLAB_SECRET_KEY="CHANGE_ME_TO_A_SECURE_RANDOM_KEY"
OPTLAB_ACCESS_TOKEN_MINUTES=30

# ── 管理员认证 JWT（独立于用户系统） ──────────────────
# 管理员令牌过期时间（小时），默认 168 = 7 天
OPTLAB_ADMIN_TOKEN_EXPIRE_HOURS=168
# 以下由系统自动写入（通过 /admin 注册或后台管理页面）：
# OPTLAB_ADMIN_USERNAME="admin"
# OPTLAB_ADMIN_PASSWORD_HASH="<argon2-hash>"
# OPTLAB_ADMIN_JWT_SECRET="<random-secret>"

# ── LLM 配置（OpenAI 兼容接口） ────────────────────────
# 支持 DeepSeek / OpenAI / 本地模型等任意兼容服务
LLM_BASE_URL="https://api.deepseek.com/v1"
LLM_MODEL_ID="deepseek-chat"
LLM_API_KEY="CHANGE_ME_LLM_KEY"
LLM_TEMPERATURE=0.25

# ── 聊天历史 ──────────────────────────────────────────
CHAT_HISTORY_WINDOW_ROUNDS=10
CHAT_MESSAGE_RETENTION_DAYS=30
