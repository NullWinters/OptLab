# database：默认使用 SQLite，可通过 OPTLAB_DB_URI 覆盖为 PostgreSQL 等
OPTLAB_DB_URI="postgresql+asyncpg://username:password@address/database"

# auth / jwt
OPTLAB_SECRET_KEY="CHANGE_ME_TO_A_SECURE_RANDOM_KEY"
OPTLAB_ACCESS_TOKEN_MINUTES=30

# LLM
# 为了方便本地启动，如果未设置环境变量则给一个占位符字符串，
# 这样 AI 助手相关代码可以正常初始化；真正调用 DeepSeek 时仍需要替换为真实密钥。
DEEPSEEK_API_KEY="CHANGE_ME_DEEPSEEK_KEY"
DEEPSEEK_MODEL="deepseek-chat"
DEEPSEEK_TEMPERATURE=0.25

# 聊天历史配置
CHAT_HISTORY_WINDOW_ROUNDS=10
CHAT_MESSAGE_RETENTION_DAYS=30
