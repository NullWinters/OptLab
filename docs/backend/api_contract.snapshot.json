{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "OptLab Backend API Snapshot (hand-maintained, not OpenAPI-generated)",
  "description": "与仓库 routers/schemas 对齐的接口快照，供合作者机器解析或导入文档工具。",
  "baseUrlRelative": "/",
  "authentication": {
    "type": "http",
    "scheme": "bearer",
    "bearerFormat": "JWT",
    "header": "Authorization",
    "prefix": "Bearer ",
    "tokenClaims": {
      "sub": "user id as string",
      "email": "user email",
      "exp": "unix exp (UTC)"
    },
    "loginEndpoint": {
      "method": "POST",
      "path": "/auth/login",
      "contentType": "application/json",
      "requestBody": {
        "identifier": "string (email or username)",
        "password": "string"
      },
      "response200": {
        "user": { "id": "integer", "email": "string", "username": "string" },
        "token": "string (JWT)"
      }
    }
  },
  "frontendStorage": {
    "localStorage": {
      "optlab_token": "JWT string",
      "optlab_user": "JSON string of user object from /auth/me or login response"
    }
  },
  "endpoints": [
    {
      "prefix": "/auth",
      "routes": [
        {
          "method": "POST",
          "path": "/auth/register",
          "auth": false,
          "body": { "email": "string", "username": "string", "password": "string", "confirm_password": "string" },
          "response": "UserSchema"
        },
        {
          "method": "POST",
          "path": "/auth/login",
          "auth": false,
          "body": { "identifier": "string", "password": "string" },
          "response": "LoginOut"
        },
        {
          "method": "GET",
          "path": "/auth/me",
          "auth": true,
          "response": "UserSchema"
        }
      ]
    },
    {
      "prefix": "/experiments",
      "routes": [
        {
          "method": "GET",
          "path": "/experiments/notes/{experiment_key}",
          "auth": true,
          "response": "ExperimentNoteOut"
        },
        {
          "method": "PUT",
          "path": "/experiments/notes/{experiment_key}",
          "auth": true,
          "body": { "reflection": "string", "extra_data": "object|null" },
          "response": "ExperimentNoteOut"
        },
        {
          "method": "GET",
          "path": "/experiments/notes/{experiment_key}/export",
          "auth": true,
          "response": "text/markdown attachment"
        },
        {
          "method": "POST",
          "path": "/experiments/records",
          "auth": true,
          "body": {
            "alias": "string 1..255",
            "source_page": "string (page id)",
            "payload": "object (arbitrary JSON)"
          },
          "response": "ExperimentRecordDetail"
        },
        {
          "method": "GET",
          "path": "/experiments/records",
          "auth": true,
          "response": "ExperimentRecordListItem[]"
        },
        {
          "method": "GET",
          "path": "/experiments/records/{record_id}",
          "auth": true,
          "response": "ExperimentRecordDetail"
        },
        {
          "method": "PATCH",
          "path": "/experiments/records/{record_id}",
          "auth": true,
          "body": { "alias": "string" },
          "response": "ExperimentRecordDetail"
        },
        {
          "method": "DELETE",
          "path": "/experiments/records/{record_id}",
          "auth": true,
          "response": "204 No Content"
        },
        {
          "method": "GET",
          "path": "/experiments/records/{record_id}/export",
          "auth": true,
          "response": "text/csv; utf-8-sig attachment"
        }
      ]
    },
    {
      "prefix": "/notes",
      "routes": [
        {
          "method": "PUT",
          "path": "/notes/item/{item_id}",
          "auth": true,
          "body": { "title": "string|null", "content": "string|null", "sort_order": "int|null" },
          "response": "NoteItemOut"
        },
        {
          "method": "DELETE",
          "path": "/notes/item/{item_id}",
          "auth": true,
          "response": "204 No Content"
        },
        {
          "method": "GET",
          "path": "/notes/{experiment_key}/export",
          "auth": true,
          "response": "text/markdown attachment"
        },
        {
          "method": "POST",
          "path": "/notes/{experiment_key}/ai-generate",
          "auth": true,
          "body": "object (experiment snapshot: params, iteration_log, _behavior, ...)",
          "response": "NoteItemOut"
        },
        {
          "method": "GET",
          "path": "/notes/{experiment_key}",
          "auth": true,
          "response": "NoteItemOut[]"
        },
        {
          "method": "POST",
          "path": "/notes/{experiment_key}",
          "auth": true,
          "body": { "title": "string", "content": "string", "sort_order": "int" },
          "response": "NoteItemOut"
        }
      ]
    },
    {
      "prefix": "/api/assistant",
      "routes": [
        {
          "method": "POST",
          "path": "/api/assistant/chat",
          "auth": false,
          "body": {
            "message": "string",
            "page_id": "string",
            "guidebook": "string",
            "buttons": [{ "id": "string", "description": "string", "type": "string" }]
          },
          "response": { "text": "string", "highlight_ids": "string[]" }
        }
      ]
    }
  ],
  "database": {
    "engine": "SQLAlchemy 2 async create_async_engine",
    "session": "AsyncSessionFactory from models/__init__.py; FastAPI Depends(get_session)",
    "initScript": "python scripts/init_db.py",
    "defaultSqliteFile": "optlab.db (project CWD, gitignored)",
    "tables": [
      {
        "name": "user",
        "columns": [
          { "name": "id", "type": "Integer PK autoincrement" },
          { "name": "email", "type": "String(255) UNIQUE" },
          { "name": "username", "type": "String(255)" },
          { "name": "_password", "type": "String(255) hashed" }
        ]
      },
      {
        "name": "experiment_note",
        "fk": "user_id -> user.id ON DELETE CASCADE",
        "columns": [
          { "name": "id", "type": "Integer PK" },
          { "name": "user_id", "type": "FK indexed" },
          { "name": "experiment_key", "type": "String(255) indexed" },
          { "name": "reflection", "type": "String/Text" },
          { "name": "extra_data", "type": "JSON nullable" },
          { "name": "created_at", "type": "DateTime TZ" },
          { "name": "updated_at", "type": "DateTime TZ" }
        ]
      },
      {
        "name": "experiment_record",
        "fk": "user_id -> user.id ON DELETE CASCADE",
        "columns": [
          { "name": "id", "type": "Integer PK" },
          { "name": "user_id", "type": "FK indexed" },
          { "name": "alias", "type": "String(255)" },
          { "name": "source_page", "type": "String(255) indexed" },
          { "name": "payload", "type": "JSON required" },
          { "name": "created_at", "type": "DateTime TZ" }
        ]
      },
      {
        "name": "note_item",
        "fk": "user_id -> user.id ON DELETE CASCADE",
        "columns": [
          { "name": "id", "type": "Integer PK" },
          { "name": "user_id", "type": "FK indexed" },
          { "name": "experiment_key", "type": "String(255) indexed" },
          { "name": "title", "type": "String(500)" },
          { "name": "content", "type": "Text" },
          { "name": "sort_order", "type": "Integer" },
          { "name": "created_at", "type": "DateTime TZ" },
          { "name": "updated_at", "type": "DateTime TZ" }
        ]
      }
    ],
    "handbookMarkdown": "docs/backend/OPTLAB_DATABASE_GUIDE.md"
  },
  "environmentVariables": [
    "OPTLAB_DB_URI",
    "OPTLAB_SECRET_KEY",
    "OPTLAB_ACCESS_TOKEN_MINUTES",
    "DEEPSEEK_API_KEY",
    "DEEPSEEK_MODEL",
    "DEEPSEEK_TEMPERATURE"
  ]
}
